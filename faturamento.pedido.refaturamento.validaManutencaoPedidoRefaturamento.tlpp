#include "protheus.ch"

namespace faturamento.pedido.refaturamento

/*/ {Protheus.doc} ValidaManutencaoPedido

Validar se pedido de venda pode ser excluido,alterado ou copia, caso seja gerada via refaturamento

@type function
@author Elcilei Lopes - DsmSolutions
@since 09/12/2025
@version P12
@database ORACLE
/*/
User Function ValidaManutencaoPedido()
	Local lRet  := .T.  as logical

	Default lExluirPVRefaturamento	:= .F.

	If !( lExluirPVRefaturamento == .T. )
	
		dbSelectArea("SZ7")
		SZ7->(dbSetOrder(5))

		If ( SZ7->(dbSeek(FWxFilial("SZ7")+SC5->C5_NUM)) ) .And. ( SZ7->Z7_STATUS == "2")

			If ( ALTERA == .T. )
				FWAlertWarning("Pedido Venda n„o pode ser Alterado."+CRLF+"Gerado pelo processo de refaturamento.","Estorno de TransferÍncia")
			ElseIf !( INCLUI ) .And. !( ALTERA )
				FWAlertWarning("Pedido Venda n„o pode ser Excluido."+CRLF+"Gerado pelo processo de refaturamento.","Estorno de TransferÍncia")
			ElseIf INCLUI .And. IsInCallStack("A410COPIA")
				FWAlertWarning("Pedido Venda n„o pode ser copiado."+CRLF+"Gerado pelo processo de refaturamento.","Estorno de TransferÍncia")
			Endif

			lRet := .F.
		Endif
	Endif

Return lRet
