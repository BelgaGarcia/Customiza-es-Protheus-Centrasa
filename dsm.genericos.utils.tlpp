/*/{Protheus.doc} sequencialClienteFornecedor
Controle sequencial Cadastro de Clientes e Fornecedores
@type function
@author rodolfomagalhaes
@since 05/06/2024
/*/
User Function sequencialClienteFornecedor(cCodigoTabela,cCGC)

	// Local cQuery           := ""
	// Local cAliasSQL        := ""
	Local lGeracaoCodigoOK := .T.
	Local cCodigoSequencial:= "00000001"
	Local cCodigoLoja      := "01"

	default cCodigoTabela := ""
	default cCGC := ""

	If !Empty(cCodigoTabela) .AND. !Empty(cCGC)

		cCGC  := StrTran(cCGC , ".", "")
		cCGC  := StrTran(cCGC , "-", "")
		cCGC  := StrTran(cCGC , "/", "")

		Do Case
		Case cCodigoTabela == "SA1"

			DbSelectArea("SA1")
			SA1->(DbSetORder(1))

			If len(alltrim(cCGC)) == 14

				cCodigoSequencial := Avkey(Substr(cCGC,1,8),"A1_COD")
				cCodigoLoja := AvKey(Substr(cCGC,9,4),"A1_LOJA")

				If !SA1->(DBSeek(xFilial("SA1")+cCodigoSequencial+cCodigoLoja))

					M->A1_COD := cCodigoSequencial
					M->A1_LOJA := cCodigoLoja

				Else
					lGeracaoCodigoOK := .F.
				EndIf

			Else

				While SA1->(DbSeek(xFilial("SA1")+cCodigoSequencial+cCodigoLoja))

					cCodigoSequencial := SOMA1(cCodigoSequencial)

				End Do

				M->A1_COD := cCodigoSequencial
				M->A1_LOJA := cCodigoLoja

			EndIF

		Case cCodigoTabela == "SA2"

			DbSelectArea("SA2")
			SA2->(DbSetORder(1))

			If len(alltrim(cCGC)) == 14

				cCodigoSequencial := Avkey(Substr(cCGC,1,8),"A2_COD")
				cCodigoLoja := AvKey(Substr(cCGC,9,4),"A2_LOJA")

				If !SA2->(DBSeek(xFilial("SA2")+cCodigoSequencial+cCodigoLoja))

					M->A2_COD := cCodigoSequencial
					M->A2_LOJA := cCodigoLoja

				Else
					lGeracaoCodigoOK := .F.
				EndIf

			Else

				While SA2->(DbSeek(xFilial("SA2")+cCodigoSequencial+cCodigoLoja))

					cCodigoSequencial := SOMA1(cCodigoSequencial)

				End Do

				M->A2_COD := cCodigoSequencial
				M->A2_LOJA := cCodigoLoja

			EndIF

		End Case

	EndIf

Return lGeracaoCodigoOK

/*/{Protheus.doc} checarFaturamentoAntecipado
Verificar a existencia de Faturamento Antecipado
@type function
@author rodolfomagalhaes
@since 05/06/2024

@see MT100LOK
/*/
User Function checarFaturamentoAntecipado(cItemValidado, cIdentificacaoBobina)

	Local lExist           := .F.
	Local lAlteraPedido	   := .F.
	Local cMensagem        := "ValidaÁ„o automatica sobre Faturamento Antecipado:"+CRLF+CRLF
	Local aCabecalhoPedido := {}
	Local aItensPedido     := {}
	Local cOper1Fis        := Alltrim(SuperGetMV("ZV_C6OPER1", .F., "")) // Sem NF BENEFICIAMENTO
	Local cOper2Fis        := Alltrim(SuperGetMV("ZV_C6OPER2", .F., "")) // Com NF BENEFICIAMENTO
	Local nCount		   := 0

	Private lMsErroAuto    := .F.
	Private lMsHelpAuto    := .F.
	Private lAutoErrNoFile := .T.

	If !Empty(cIdentificacaoBobina)

		DbSelectArea("SC5")
		SC5->(DBOrderNickname("DSMSC5001")) // C5_FILIAL + C5_ZLOTCTL
		If SC5->(DbSeek(FwxFilial("SC5")+AvKey(cIdentificacaoBobina,"C5_ZLOTCTL")))

			If !Empty(SC5->C5_NOTA)

				lExist := .T.
				cMensagem += "Faturamento antecipado localizado. Item: "+Alltrim(cItemValidado)+CRLF+CRLF
				cMensagem += TAB+" ID bobina: "+cIdentificacaoBobina+CRLF
				cMensagem += TAB+" Pedido: "+SC5->C5_NUM+CRLF
				cMensagem += TAB+" Nota: "+SC5->C5_NOTA+CRLF
				cMensagem += TAB+" Serie: "+SC5->C5_SERIE+CRLF
				cMensagem += CRLF
				cMensagem += TAB+" Sera sugerido o Codigo OperaÁao fiscal do parametro ZV_D1OPER1"+CRLF
				ShowLog(cMensagem)

			Else
				// Ajustar a OPERACAO do Pedido de venda
				lExist := .F.

				aadd(aCabecalhoPedido,{"C5_NUM",SC5->C5_NUM,Nil})

				DbSelectArea("SC6")
				SC6->(DbSetORder(1))
				If SC6->(DbSeek(FwxFilial("SC6")+SC5->C5_NUM))

					Do While SC6->(!EOF()) .AND. SC6->(C6_FILIAL+C6_NUM) == SC5->(C5_FILIAL+C5_NUM)

						aLinha := {}
						aadd(aLinha, {"LINPOS"    , "C6_ITEM"      , SC6->C6_ITEM})
						aadd(aLinha, {"AUTDELETA" , "N"            , Nil})
						aadd(aLinha, {"C6_PRODUTO", SC6->C6_PRODUTO, Nil})

						If SC6->(C6_NFORI+C6_SERIORI+C6_ITEMORI) == SDH->(DH_NDOC+DH_SDOC+DH_ITEM)
							lAlteraPedido := .T.
							aadd(aLinha, {"C6_OPER", cOper2Fis, Nil})
						else
							aadd(aLinha, {"C6_OPER", cOper1Fis, Nil})
						EndIf

						aadd(aLinha, {"C6_QTDVEN" , SC6->C6_QTDVEN , Nil})
						aadd(aLinha, {"C6_PRCVEN" , SC6->C6_PRCVEN , Nil})
						aadd(aLinha, {"C6_PRUNIT" , SC6->C6_PRUNIT , Nil})
						aadd(aLinha, {"C6_VALOR"  , SC6->C6_VALOR  , Nil})

						aadd(aItensPedido, aLinha)

						SC6->(DbSkip())

					End Do

					If lAlteraPedido
						nOpcX := 4
						MSExecAuto({|a, b, c, d| MATA410(a, b, c, d)}, aCabecalhoPedido, aItensPedido, nOpcX, .F.)
						If !lMsErroAuto
							ConOut("Alterado com sucesso! " + cDoc)
						Else
							ConOut("Erro na alteraÁ„o!")
							cLogErro := ''
							aErroAuto := GetAutoGRLog()
							For nCount := 1 To Len(aErroAuto)
								cLogErro += StrTran(StrTran(aErroAuto[nCount], "<", ""), "-", "") + " "
								ConOut(cLogErro)
							Next nCount

							ShowLog(cLogErro)
						EndIf
					EndIf
				EndIf
			EndIf
		EndIf
	EndIf
return lExist

/*/{Protheus.doc} checarLoteDigitadoBobina
Validar LOTE Digitado D1_LOTECTL e D1_LOTEFOR
@type function
@author rodolfomagalhaes
@since 05/06/2024

@obs
 dsm.genericos.U_checarLoteDigitadoBobina(GDFieldGet("D1_COD"),M->D1_LOTECTL,"D1_LOTECTL")

@see MT100LOK
/*/
User Function checarLoteDigitadoBobina(cCodigoProduto, cNumeroLote, cNomeCampo, cOperacao)

	Local lContinua   := .T.
	Local nIndex      := 0
	Local nLinhaAtual := n
	Local nPosLote    := GDFIELDPOS("D1_LOTECTL")
	Local cOper6Fis   := Strtran(Alltrim(SuperGetMV("ZV_D1OPER6", .F., "")),";","#")

	DbSelectArea("SB8")
	If !Empty(cNumeroLote) .AND. !FWIsInCallStack("NFENFECOB") .AND. !FWIsInCallStack("compras.entrada.u_Notagerencial") .And. !FWIsInCallStack("faturamento.pedido.u_Enviasaldogerencial");
		.AND. !FWIsInCallStack("compras.entrada.u_devolucaoIndustrializacao") // Amarracao NF triangular

		Do Case
		Case Alltrim(cNomeCampo) == "D1_LOTECTL"

			If !(Alltrim(CESPECIE) == "GER") // Acrecentar regra para devolucao #gabriel rodolfo

				cQuery := "SELECT * FROM "+RetSQLTab("SB8") + CRLF
                cQuery += " INNER JOIN "+RetSQLTab("SD1")+" ON " + CRLF
                cQuery += "   "+RetSqlFil("SD1") + CRLF
                cQuery += "     AND D1_DOC = B8_DOC" + CRLF
                cQuery += "     AND D1_SERIE = B8_SERIE" + CRLF
                cQuery += "     AND D1_FORNECE = B8_CLIFOR" + CRLF
                cQuery += "     AND D1_LOJA = B8_LOJA" + CRLF
				cQuery += "     AND D1_LOTECTL = B8_LOTECTL" + CRLF
                cQuery += "     AND "+RetSqlDel("SD1") + CRLF
                cQuery += " WHERE 1=1 " + CRLF
                cQuery += "  AND " + RetSqlFil("SB8") + CRLF
                cQuery += "  AND B8_LOCAL NOT LIKE 'Z%' " + CRLF
                cQuery += "  AND B8_LOTECTL = '"+cNumeroLote+"' " + CRLF
                cQuery += "  AND NOT (B8_DOC = '"+CNFISCAL+"' AND B8_SERIE = '"+CSERIE+"' AND B8_CLIFOR = '"+CA100FOR+"' AND B8_LOJA = '"+CLOJA+"')" + CRLF

				cAlias := MPSysOpenQuery( cQuery )

				If !(cAlias)->(EOF())
					lContinua := .F.
					cTexto := "ID / LOTE "+Alltrim(cNumeroLote)+" j· utilizado!"+CRLF
					cTexto += "NF "+Alltrim((cAlias)->B8_DOC)+CRLF
					cTexto += "SERIE "+Alltrim((cAlias)->B8_SERIE)+CRLF
					cTexto += "CLI/FOR "+Alltrim((cAlias)->B8_CLIFOR)+CRLF
					cTexto += "LOJA "+Alltrim((cAlias)->B8_LOJA)+CRLF

					If Alltrim(cOperacao) $ cOper6Fis 
						cTexto += "Deseja continuar?"+CRLF
						If FWAlertNoYes(cTexto, "Controle de Lote")
							lContinua := .T.
						EndIf
					Else 
					FWAlertWarning(cTexto, "Controle de Lote")
					EndiF
				EndiF

				(cAlias)->(DBCloseArea())
			EndIf

			// DbSelectArea("SB8")
			// SB8->(DbSetORder(2)) // B8_FILIAL+B8_NUMLOTE+B8_LOTECTL
			// If SB8->(DbSeek(FwxFilial("SB8")+Avkey("","B8_NUMLOTE")+Avkey(cNumeroLote,"B8_LOTECTL")))

			// 	While SB8->(!EOF()) .AND. SB8->(B8_FILIAL+B8_NUMLOTE+B8_LOTECTL) == FwxFilial("SB8")+Avkey("","B8_NUMLOTE")+Avkey(cNumeroLote,"B8_LOTECTL")

			// 		// If !(SB8->B8_DOC == CNFISCAL .AND. SB8->B8_SERIE == CSERIE .AND. SB8->B8_CLIFOR == CA100FOR .AND. SB8->B8_LOJA == CLOJA)
			// 		// If (SB8->B8_CLIFOR == CA100FOR .AND. SB8->B8_LOJA == CLOJA .AND. SB8->B8_SALDO == 0)

			// 		// 	M->D1_DTVALID := SB8->B8_DTVALID
			// 		// 	lContinua := .T.

			// 		// Else

			// 		lContinua := .F.
			// 		cTexto := "ID / LOTE "+Alltrim(cNumeroLote)+" j· utilizado!"+CRLF
			// 		cTexto += "NF "+Alltrim(SB8->B8_DOC)+CRLF
			// 		cTexto += "SERIE "+Alltrim(SB8->B8_SERIE)+CRLF
			// 		cTexto += "CLI/FOR "+Alltrim(SB8->B8_CLIFOR)+CRLF
			// 		cTexto += "LOJA "+Alltrim(SB8->B8_LOJA)+CRLF
			// 		FWAlertWarning(cTexto, "Controle de Lote")
			// 		EXIT

			// 		// EndIf

			// 		SB8->(DbSkip())

			// 	EndDo

			// EndIf

			If lContinua

				For nIndex := 1 to len(Acols)

					If !(nIndex == nLinhaAtual)

						If Alltrim(aCols[nIndex][nPosLote]) == Alltrim(cNumeroLote)
							lContinua := .F.
							FWAlertWarning("ID / LOTE "+Alltrim(cNumeroLote)+" j· utilizado nesta NF!", "Controle de Lote")
						EndIf

					EndIf

				Next nIndex

			EndIf

		End Case

	EndIf

Return lContinua

/*/{Protheus.doc} whenh601
Conttrolar WHEN campo H6_ZPESO
@type function
@author rodolfomagalhaes
@since 16/09/2024
/*/
User Function whenh601()

	Local lEditar := .F.

	If !Empty(M->H6_PRODUTO)
		DbSelectArea("SB1")
		SB1->(DbSetORder(1))
		SB1->(DbSeek(FwxFilial("SB1")+M->H6_PRODUTO))
		Do Case
		Case M->H6_OPERAC == "01"
			lEditar := .F.
			If !(SB1->B1_UM $("KG|TL"))
				M->H6_ZPESO := 1
			Else
				M->H6_ZPESO := 0
			EndIf
		Case M->H6_OPERAC == "02"
			If !(SB1->B1_UM $("KG|TL"))
				lEditar := .T.
			EndIf
		End Case
	EndIf

Return lEditar

