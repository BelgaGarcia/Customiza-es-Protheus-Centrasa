/*/{Protheus.doc} fGerarLoteApontamento
Controlar sugest„o numero do LOTE a ser gerado nos apontamentos MOD I e MOD II
@type function
@author rodolfomagalhaes
@since 16/09/2024
/*/
User Function fGerarLoteApontamento(cCodigoOperacao)

	Local nNumLote := Alltrim(M->H6_OP)+"01"
	Local cQuery   := ""
	Local cQryTmp  := ""

	Default cCodigoOperacao := ""

	// If Alltrim(cCodigoOperacao) == "02" .AND. !Empty(M->H6_OP)
	If !Empty(M->H6_OP)

		M->H6_LOTECTL := SPACE(TamSx3("H6_LOTECTL")[1])
		M->H6_DTVALID := StoD("")

		DbSelectArea("SB1")
		SB1->(DbSetORder(1))
		SB1->(DbSeek(FwxFilial("SB1")+M->H6_PRODUTO))

		If Alltrim(SB1->B1_RASTRO) == "L"

			cQuery := "SELECT MAX(H6_LOTECTL) MAXLOTEATUAL "+CRLF
			cQuery += " FROM "+RetSqlTab("SH6") + " " + CRLF
			cQuery += "	WHERE 1=1 "+CRLF
			cQuery += "		AND " + RetSqlFil("SH6")+" "+CRLF
			cQuery += "		AND " + RetSqlDel("SH6")+" "+CRLF
			cQuery += "		AND H6_OP = "+ValToSql(M->H6_OP)+" "+CRLF
			cQuery += "		AND H6_OPERAC = '02' "+CRLF

			cQuery := ChangeQuery(cQuery)
			cQryTmp := MPSysOpenQuery( cQuery )

			If (cQryTmp)->(!EOF())
				If Substr(Alltrim((cQryTmp)->MAXLOTEATUAL),1,11) == Alltrim(M->H6_OP)
					M->H6_LOTECTL := SOMA1((cQryTmp)->MAXLOTEATUAL)
				Else
					M->H6_LOTECTL := nNumLote
				EndIf
			Else
				M->H6_LOTECTL := nNumLote
			EndIf

			DbSelectArea("SB1")
			SB1->(DbSetOrder(1))
			If SB1->(DbSeek(FwxFilial("SB1")+M->H6_PRODUTO))

				If SB1->B1_PRVALID == 0
					M->H6_DTVALID := (DDATABASE + (50 * 365))
				EndIf

			EndIf

			(cQryTmp)->(DBCloseArea())
		EndIf
	EndIf

Return .T.

/*/{Protheus.doc} fGerarLoteApontamento
Controlar sugest„o numero do LOTE a ser gerado nos apontamentos MOD I e MOD II Para ser utilizado em execauto
@type function
@author rodolfomagalhaes
@since 16/09/2024
/*/
User Function fBuscaProximoLote(cNumeroOrdemProducao, cCodigoProdutoProduzido)

	Local nNumLote  := Alltrim(cNumeroOrdemProducao)+"01"
	Local nNewLote  := ""
	Local dValidade := DDATABASE+SB1->B1_PRVALID
	Local cQuery    := ""
	Local cQryTmp   := ""
	Local aNovoLote := {nNumLote, dValidade, .F.}

	DbSelectArea("SB1")
	SB1->(DbSetORder(1))
	SB1->(DbSeek(FwxFilial("SB1")+AvKey(cCodigoProdutoProduzido, "H6_PRODUTO")))

	If Alltrim(SB1->B1_RASTRO) == "L"

		cQuery := "SELECT MAX(CAST(B8_LOTECTL AS NUMERIC)) MAXLOTEATUAL "+CRLF
		cQuery += " FROM "+RetSqlTab("SB8") + " " + CRLF
		cQuery += "	WHERE 1=1 "+CRLF
		cQuery += "		AND " + RetSqlFil("SB8")+" "+CRLF
		cQuery += "		AND " + RetSqlDel("SB8")+" "+CRLF
		cQuery += "		AND B8_LOTECTL LIKE '"+AllTrim(cNumeroOrdemProducao)+"%' "+CRLF
		//cQuery += "		AND H6_OPERAC = '02' "+CRLF

		cQuery := ChangeQuery(cQuery)
		cQryTmp := MPSysOpenQuery( cQuery )

		If (cQryTmp)->(!EOF())
			nNewLote := StrZero((cQryTmp)->MAXLOTEATUAL,13)
			If Substr(nNewLote,1,11) == Alltrim(cNumeroOrdemProducao)
				aNovoLote := {SOMA1(nNewLote), dValidade, .F.}
			Else
				aNovoLote := {nNumLote, dValidade, .F.}
			EndIf
		Else
			aNovoLote := {nNumLote, dValidade, .F.}
		EndIf

		(cQryTmp)->(DBCloseArea())
	EndIf

Return aNovoLote

/*/{Protheus.doc} fAddItemPedidoVendaProducao
Adicionar no Pedido de Venda que originou o plano de corte o produto apontado para faturamento
@type function
@version 1.0
@author rodolfomagalhaes
@since 25/09/2024

/*/
User Function fAddItemPedidoVendaProducao()

	Local aCabecalhoPedido := {}
	Local aLinha           := {}
	Local aItensPedido     := {}
	Local cProxItem        := "01"
	Local cOperacaoFis     := "" //Alltrim(SuperGetMV("ZV_ZV_C6OPE10", .F., "61")) // Operacao Faturamento
	Local nCount           := 0
	Local aArea            := GetArea()
	Local nValorUnitario   := 0
	Local nValorTabela     := 0
	Local cPedidoCliente   := ""
	Local cItPedidoCliente := ""

	Private lMsErroAuto    := .F.
	Private lMsHelpAuto    := .T.
	Private lAutoErrNoFile := .T.

	If Alltrim(SH6->H6_OPERAC) == "02" .AND. Substr(Alltrim(SH6->H6_OP),9,3) == "001"

		DbSelectArea("SC2")
		SC2->(DbSetOrder(1))
		If SC2->(DbSeek(FwxFilial("SC2")+SH6->H6_OP))

			If !Empty(SC2->C2_PEDIDO)

				DbSelectArea("SC5")
				SC5->(DbSetOrder(1)) // C5_FILIAL + C5_ZLOTCTL
				If SC5->(DbSeek(FwxFilial("SC5")+SC2->C2_PEDIDO))

					If Empty(SC5->C5_NOTA)

						// Begin Sequence

						aadd(aCabecalhoPedido,{"C5_NUM", SC5->C5_NUM, Nil})

						DbSelectArea("SC6")
						SC6->(DbSetORder(1))
						If SC6->(DbSeek(FwxFilial("SC6")+SC5->C5_NUM))

							Do While SC6->(!EOF()) .AND. SC6->(C6_FILIAL+C6_NUM) == SC5->(C5_FILIAL+C5_NUM)

								If val(SC6->C6_ITEM) > Val(cProxItem)
									cProxItem := SC6->C6_ITEM
								EndIf

								If nValorUnitario == 0 .AND. SC6->C6_PRODUTO == SH6->H6_PRODUTO
									nValorUnitario := SC6->C6_PRCVEN
									cPedidoCliente := SC6->C6_NUMPCOM
									cItPedidoCliente := SC6->C6_ITEMPC
									cOperacaoFis	:= SC6->C6_OPER
								EndIf

								SC6->(DbSkip())

							End Do

						EndIf

						aLinha := {}
						DbSelectArea("SB1")
						SB1->(DbSeek(FwxFilial("SB1")+SH6->H6_PRODUTO))
						// aadd(aLinha, {"LINPOS"    , "C6_ITEM"             , SOMA1(cProxItem)})
						aadd(aLinha, {"AUTDELETA" , "N"             , Nil})
						aadd(aLinha, {"C6_ITEM"   , SOMA1(cProxItem), Nil})
						aadd(aLinha, {"C6_PRODUTO", SH6->H6_PRODUTO , Nil})
						aadd(aLinha, {"C6_QTDVEN" , SH6->H6_QTDPROD , Nil})
						aadd(aLinha, {"C6_LOCAL"  , SC2->C2_LOCAL   , Nil})

						DbSelectArea("SA1")
						SA1->(DbSetORder(1))
						SA1->(Dbseek(FwxFilial("SA1")+SC5->(C5_CLIENTE+C5_LOJACLI)))

						aadd(aLinha, {"C6_LOCALIZ", SA1->A1_CGC     , Nil})

						If !Empty(SC5->C5_TABELA)
							nValorTabela := MaTabPrVen(SC5->C5_TABELA,SH6->H6_PRODUTO,SH6->H6_QTDPROD,SC5->C5_CLIENTE,SC5->C5_LOJACLI,SC5->C5_MOEDA,SC5->C5_EMISSAO)
							If nValorTabela > 0
								nValorUnitario := nValorTabela
							EndIf
						EndIf

						DbSelectArea("SA7")
						SA7->(DbSetOrder(1))
						If SA7->(DbSeek(FwxFilial("SA7")+SC5->C5_CLIENTE+SC5->C5_LOJACLI+SH6->H6_PRODUTO))
							If SA7->A7_ZUMNFE == "KG"
								nValorUnitario	:= (SH6->H6_ZPESO * SA7->A7_ZVLRUN) / SH6->H6_QTDPROD
							ElseIf SA7->A7_ZUMNFE == "TL"
								nValorUnitario	:= ((SH6->H6_ZPESO / 1000) * SA7->A7_ZVLRUN) / SH6->H6_QTDPROD
							EndIf
						EndIf

						If nValorUnitario == 0
							nValorUnitario := 1
						EndIf

						aadd(aLinha, {"C6_PRCVEN", nValorUnitario                           , Nil})
						aadd(aLinha, {"C6_PRUNIT", nValorUnitario                           , Nil})
						aadd(aLinha, {"C6_VALOR" , ROUND(SH6->H6_QTDPROD * nValorUnitario,2), Nil})

						aadd(aLinha, {"C6_OPER"   , cOperacaoFis             , Nil})
						cTES := MaTesInt(2,cOperacaoFis,SC5->C5_CLIENTE,SC5->C5_LOJACLI,If(SC5->C5_TIPO$"DB","F","C"),SH6->H6_PRODUTO)

						aadd(aLinha, {"C6_TES"    , cTES                  , Nil})
						aadd(aLinha, {"C6_LOTECTL", SH6->H6_LOTECTL       , Nil})
						aadd(aLinha, {"C6_NUMOP"  , Substr(SH6->H6_OP,1,6), Nil})
						aadd(aLinha, {"C6_ITEMOP" , Substr(SH6->H6_OP,7,2), Nil})
						aadd(aLinha, {"C6_NUMPCOM", cPedidoCliente        , Nil})
						aadd(aLinha, {"C6_ITEMPC" , cItPedidoCliente      , Nil})

						If SB1->B1_UM $ "KG|TL"
							aadd(aLinha, {"C6_ZPESO"  , SH6->H6_QTDPROD , Nil})
							aadd(aLinha, {"C6_ZPESOBT", SH6->H6_ZPESOBT , Nil})
						Else
							aadd(aLinha, {"C6_ZPESO"  , SH6->H6_ZPESO   , Nil})
							aadd(aLinha, {"C6_ZPESOBT", SH6->H6_ZPESOBT , Nil})
						EndIf

						aadd(aItensPedido, aLinha)

						nOpcX := 4

						MSExecAuto({|a, b, c, d| MATA410(a, b, c, d)}, aCabecalhoPedido, aItensPedido, nOpcX, .F.)
						If lMsErroAuto

							cLogErro := ''
							aErroAuto := GetAutoGRLog()
							For nCount := 1 To Len(aErroAuto)
								cLogErro += StrTran(StrTran(aErroAuto[nCount], "<", ""), "-", "") + " " + CRLF
								// ConOut(cLogErro)
							Next nCount
							ShowLog(cLogErro)
							// DisarmTransaction()
						EndIf
						// End Sequence
					EndIf
				EndIf
			EndIf
		EndIf
	EndIf

	RestArea(aArea)

Return !lMsErroAuto

/*/{Protheus.doc} fRemItemPedidoVendaProducao
Remover do Pedido de Venda que originou o plano de corte o produto estornado para faturamento
@type function
@version 1.0
@author rodolfomagalhaes
@since 25/09/2024

/*/
User Function fRemItemPedidoVendaProducao(oSay)
	Local nAcao            := PARAMIXB[1]
	Local lRet             := .T.
	Local aArea            := GetArea()
	Local aCabecalhoPedido := {}
	Local aLinha           := {}
	Local aItensPedido     := {}
	Local nCount           := 0

	Private lMsErroAuto    := .F.
	Private lMsHelpAuto    := .F.
	Private lAutoErrNoFile := .T.

	If nAcao == 2 //Operador confirmou estorno
		If Alltrim(SH6->H6_OPERAC) == "02" .AND. Substr(Alltrim(SH6->H6_OP),9,3) == "001"

			// oSay:SetText("Removendo Dados..") // oSay falhando ao utilizar via execauto....

			DbSelectArea("SC2")
			SC2->(DbSetOrder(1))
			If SC2->(DbSeek(FwxFilial("SC2")+SH6->H6_OP))

				If !Empty(SC2->C2_PEDIDO)

					DbSelectArea("SC5")
					SC5->(DbSetOrder(1)) // C5_FILIAL + C5_ZLOTCTL
					If SC5->(DbSeek(FwxFilial("SC5")+SC2->C2_PEDIDO))

						If Empty(SC5->C5_NOTA)

							aadd(aCabecalhoPedido,{"C5_NUM", SC5->C5_NUM, Nil})

							DbSelectArea("SC6")
							SC6->(DBOrderNickname("DSMSC6001")) //
							If SC6->(DbSeek(FwxFilial("SC6")+SC5->C5_NUM+SH6->H6_PRODUTO+SH6->H6_LOTECTL))

								If Empty(SC6->C6_NOTA)

									aLinha := {}
									aadd(aLinha, {"LINPOS"    , "C6_ITEM"             , SC6->C6_ITEM})
									aadd(aLinha, {"AUTDELETA" , "S"                   , Nil})

									aadd(aItensPedido, aLinha)

									nOpcX := 4
									MSExecAuto({|a, b, c, d| MATA410(a, b, c, d)}, aCabecalhoPedido, aItensPedido, nOpcX, .F.)
									If !lMsErroAuto
										// ConOut("Alterado com sucesso! ")
										// oSay:SetText("Removido com sucesso..")
										lRet := .T.
									Else
										// ConOut("Erro na alteraÁ„o!")
										cLogErro := ''
										aErroAuto := GetAutoGRLog()
										For nCount := 1 To Len(aErroAuto)
											cLogErro += StrTran(StrTran(aErroAuto[nCount], "<", ""), "-", "") + " "
											ConOut(cLogErro)
										Next nCount

										ShowLog(cLogErro)
										lRet := .F.
									EndIf
								EndIf
							EndIf
						Else
							FWAlertWarning("Mensagem de aviso", "Item j· faturado...")
							lRet := .F.
						EndIf
					EndIf
				EndIf
			EndIf
		EndIf

		RestArea(aArea)
	EndIf

Return lRet

//-------------------------------------------------------
// CRIA ENDERE«O CASO N√O EXISTA
//-------------------------------------------------------
User Function fValidaExisteEndereco(cArmazem, cEndereco)

	Local lExiste := .T.
	Local aVetor  := {}

	DbSelectArea("SBE")
	SBE->(DbSetOrder(1))
	If !SBE->(DbSeek(FwxFilial("SBE")+AvKey(cArmazem,"BE_LOCAL")+AvKey(cEndereco,"BE_LOCALIZ")))

		DbSelectArea("SA1")
		SA1->(DbSetOrder(3))
		If SA1->(DbSeek(FwxFilial("SA1")+cEndereco))

			aVetor :={{"BE_LOCAL" ,AvKey(cArmazem,"BE_LOCAL") ,Nil},;
				{"BE_LOCALIZ", AvKey(cEndereco,"BE_LOCALIZ") , NIL},;
				{"BE_DESCRIC", Substr(SA1->A1_NOME,1,TamSx3("BE_DESCRIC")[1]), NIL},;
				{"BE_CAPACID", 0         , NIL},;
				{"BE_PRIOR"  , "ZZZ"     , NIL},;
				{"BE_ALTURLC", 0         , NIL},;
				{"BE_LARGLC" , 0         , NIL},;
				{"BE_COMPRLC", 0         , NIL},;
				{"BE_PERDA"  , 5         , NIL},;
				{"BE_STATUS" , "1"       , NIL}}

			nOpc := 3	// inclusao

			MSExecAuto({|x,y| MATA015(x,y)},aVetor, nOpc)

			If lMsErroAuto
				lExiste := .F.
			Else
				lExiste := .T.
			EndIf
		Else
			lExiste := .F.
		EndIf

	EndIf

Return lExiste
