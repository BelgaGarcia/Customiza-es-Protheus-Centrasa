Return

/*
	Query da Busca dados cliente
*/
Static Function queryBuscaDadosCliente()
	Local cQuery	:= ""	as character

	cQuery += " SELECT " + CRLF
	cQuery += "        * "	+ CRLF

	cQuery += " FROM " + CRLF
	cQuery += "     " + RetSQLTab("SA1") + CRLF

	cQuery += " WHERE " + CRLF
	cQuery += " 	    1 = 1 " + CRLF
	cQuery += "	 		AND " + RetSqlFil("SA1") + CRLF
	cQuery += " 		AND A1_COD		= '"+cCodigoFornecedor+"' " + CRLF
	cQuery += " 		AND A1_LOJA		= '"+cLojaFornecedor+"' " + CRLF
	cQuery += "	    	AND " + RetSqlDel("SA1") + CRLF
Return cQuery

/*
	Calcula Peso Total
*/
Static Function calculaPesoTotal(nPesoPA)
	Local cRetorno		:= ""	as character
	Local nPosPesoTotal	:= 0	as integer
	Local cQuery		:= ""	as character
	Local cAliasTotal
	Local cAliasParcial

	nPosPesoTotal	:= aScan(aPesoTotal, {|aX| aX[1] == cLoteBobina})

	If nPosPesoTotal > 0
		aPesoTotal[nPosPesoTotal][3]	+= nPesoPA
	Else
		cQuery := 	queryBuscaPesoMP()

		MPSysOpenQuery( cQuery, cAliasTotal := GetNextAlias() )
		
		(cAliasTotal)->(DbGoTop())
		If (cAliasTotal)->(!EoF())			
			aAdd(aPesoTotal, {cLoteBobina, (cAliasTotal)->C6_QTDVEN, nPesoPA})
		EndIf
		
		(cAliasTotal)->(DbCloseArea())

		nPosPesoTotal	:= Len(aPesoTotal)

		cQuery := 	queryBuscaPesoParcial()

		MPSysOpenQuery( cQuery, cAliasParcial := GetNextAlias() )

		(cAliasParcial)->(DbGoTop())
		If (cAliasParcial)->(!EoF())			
			aPesoTotal[nPosPesoTotal][3]	+= (cAliasParcial)->C6_ZPESO
		EndIf
		
		(cAliasParcial)->(DbCloseArea())
	EndIf

	If aPesoTotal[nPosPesoTotal][2] > aPesoTotal[nPosPesoTotal][3]
		cRetorno	:= " (Parcial)"
	Else
		cRetorno	:= " (Saldo)"
	EndIf
Return cRetorno

/*
	Query Peso MP
*/
Static Function queryBuscaPesoMP()
	Local cQuery	:= ""	as character

	cQuery += " SELECT " + CRLF
	cQuery += "        C6_QTDVEN "		+ CRLF

	cQuery += " FROM " + CRLF
	cQuery += "     " + RetSQLTab("SC6") + CRLF

	cQuery += " INNER JOIN " + CRLF
	cQuery += "     " + RetSQLTab("SB1") + CRLF
	cQuery += "     	ON" + CRLF
	cQuery += " 	    " + RetSqlFil("SB1") + CRLF
	cQuery += " 	    AND B1_COD		= C6_PRODUTO " + CRLF
	cQuery += " 	    AND B1_TIPO		= 'MP' " + CRLF
	cQuery += "	    	AND " + RetSqlDel("SB1") + CRLF

	cQuery += " WHERE " + CRLF
	cQuery += " 	    1 = 1 " + CRLF
	cQuery += "	 		AND " + RetSqlFil("SC6") + CRLF
	cQuery += " 		AND C6_NUM		= '"+IIF(lRefaturamento, cPedidoOriginal, aProdutos[nProduto][38])+"' " + CRLF
	cQuery += "	    	AND " + RetSqlDel("SC6") + CRLF
Return cQuery

/*
	Query Peso Parcial Faturado
*/
Static Function queryBuscaPesoParcial()
	Local cQuery	:= ""	as character

	cQuery += " SELECT " + CRLF
	cQuery += "        SUM(C6_ZPESO) C6_ZPESO "		+ CRLF

	cQuery += " FROM " + CRLF
	cQuery += "     " + RetSQLTab("SC6") + CRLF

	cQuery += " INNER JOIN " + CRLF
	cQuery += "     " + RetSQLTab("SB1") + CRLF
	cQuery += "     	ON" + CRLF
	cQuery += " 	    " + RetSqlFil("SB1") + CRLF
	cQuery += " 	    AND B1_COD		= C6_PRODUTO " + CRLF
	cQuery += " 	    AND B1_TIPO		<> 'MP' " + CRLF
	cQuery += "	    	AND " + RetSqlDel("SB1") + CRLF

	cQuery += " WHERE " + CRLF
	cQuery += " 	    1 = 1 " + CRLF
	cQuery += "	 		AND " + RetSqlFil("SC6") + CRLF
	cQuery += " 		AND C6_NOTA		<> '"+SF2->F2_DOC+"' " + CRLF
	cQuery += " 		AND C6_SERIE	<> '"+SF2->F2_SERIE+"' " + CRLF
	cQuery += " 		AND C6_NUM		= '"+aProdutos[nProduto][38]+"' " + CRLF
	cQuery += "	    	AND " + RetSqlDel("SC6") + CRLF
Return cQuery
