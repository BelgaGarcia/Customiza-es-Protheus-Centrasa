	cQuery += " FROM " + CRLF
	cQuery += "     " + RetSQLTab("SA2") + CRLF

	cQuery += " WHERE " + CRLF
	cQuery += " 	    1 = 1 " + CRLF
	cQuery += "	 		AND " + RetSqlFil("SA2") + CRLF
	cQuery += " 		AND A2_COD		= '"+cCodigoFornecedor+"' " + CRLF
	cQuery += " 		AND A2_LOJA		= '"+cLojaFornecedor+"' " + CRLF
	cQuery += "	    	AND " + RetSqlDel("SA2") + CRLF
Return cQuery

