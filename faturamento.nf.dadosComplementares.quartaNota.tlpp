#include "tlpp-core.th"
#include "protheus.ch"

#define CRLF chr(13) + chr(10)

namespace faturamento.nf.dadosComplementares

/*/{Protheus.doc} dadosComplementares

Dados complementares na NF (Quarta Nota e Nota Usina).

@type Function
@author Gabriel Goncalves
@since 24/10/2024
@version P12
@database MSSQL

/*/
User Function quartaNota(aProd)
	Local nPosProduto			:= 0	as integer
	
	Private cMensagemRetorno			:= ""	as character
	Private cNumeroQuartaNota			:= ""	as character
	Private dDataQuartaNota				:= StoD("")	as date
	Private dDataNotaEntrada			:= StoD("")	as date
	Private cNumeroNotaUsina			:= ""	as character
	Private cSerieUsina					:= ""	as character
	Private cTipoNotaEntrada			:= ""	as character
	Private cCodigoFornecedor			:= ""	as character
	Private cLojaFornecedor				:= ""	as character
	Private nValorItem					:= 0	as numeric
	Private cNumeroInspecao				:= ""	as character
	Private cLoteBobina					:= ""	as character
	Private cNumeroNotaCliente			:= ""	as character
	Private cClienteNota				:= ""	as character
	Private cLojaNota					:= ""	as character
	Private lRefaturamento				:= .F.	as logical
	Private cNotaRefaturamento			:= ""	as character
	Private cSerieRefaturamento			:= ""	as character
	Private cFornecedorRefaturamento	:= ""	as character
	Private cLojaRefaturamento			:= ""	as character
	Private cPedidoOriginal				:= ""	as character
	Private cCFOPMensagem				:= ""	as character
	Private aProdutos					:= aProd	as array
	Private nProduto					:= 0	as integer
	Private cMensagemFiscal				:= ""	as character
	Private cMensagemComercial			:= ""	as character
	Private aPesoTotal					:= {}	as array
	Private cIDBobinaMensagem			:= ""	as character

	If validaMensagemNoItem()
		For nPosProduto	:= 1 To Len(aProdutos)
			nProduto		:= nPosProduto
			cCFOPMensagem	:= SubStr(aProdutos[nProduto][7],2,3)

			validaRefaturamento()
			notaUsina()
			dadosQuartaNota()
			montaMensagem()
		Next nPosProduto

		cMensagemRetorno	:= cMensagemFiscal + cMensagemComercial + "."
	EndIf
Return cMensagemRetorno

/*
	Monta Mensagem de retorno
*/
Static Function montaMensagem()
	If !(cLoteBobina $ cIDBobinaMensagem)
		cMensagemFiscal		+= montaMensagemFiscal()
	EndIf

	cMensagemComercial	+= montaMensagemComercial()
Return()

/*
	Monta mensagem Fiscal
*/
Static Function montaMensagemFiscal()
	Local cRetorno	:= ""	as character

	Private cAliasFornecedor	:= ""	as character
	Private cAliasCliente		:= ""	as character

	buscaDadosFornecedor()

	If cCFOPMensagem == "902" .Or. ( cCFOPMensagem == "903" .And. cTipoNotaEntrada == "B" )
		cRetorno	:= "MATERIAL DE SUA PROPRIEDADE QUE NOS FOI ENVIADO PARA INDUSTRIALIZAÇĂO ATRAVÉS DA(s):"
		cRetorno	+= " NF " + cNumeroNotaUsina
		cRetorno	+= ", SÉRIE " + cSerieUsina
		cRetorno	+= ", DATA EMISSĂO " + DtoC(dDataNotaEntrada)
		cRetorno	+= ", VALOR " + AllTrim(Str(nValorItem)) + "."

	ElseIf cCFOPMensagem == "925" .Or. ( cCFOPMensagem == "903" .And. cTipoNotaEntrada == "N" )
		cRetorno	:= "MATERIAL DE SUA PROPRIEDADE QUE NOS FOI ENVIADO POR CONTA E ORDEM PELO"
		cRetorno	+= " FORNECEDOR " + AllTrim((cAliasFornecedor)->A2_NOME)
		cRetorno	+= " SITUADO A " + AllTrim((cAliasFornecedor)->A2_END) + " " + AllTrim((cAliasFornecedor)->A2_NR_END)
		cRetorno	+= ", BAIRRO: " + AllTrim((cAliasFornecedor)->A2_BAIRRO)
		cRetorno	+= ", CIDADE: " + AllTrim((cAliasFornecedor)->A2_MUN)
		cRetorno	+= ", ESTADO: " + AllTrim((cAliasFornecedor)->A2_EST)
		cRetorno	+= ", INSC EST " + AllTrim((cAliasFornecedor)->A2_INSCR)
		cRetorno	+= ", CNPJ " + AllTrim((cAliasFornecedor)->A2_CGC)
		cRetorno	+= ", ATRAVÉS DA NF " + cNumeroNotaUsina
		cRetorno	+= ", SÉRIE " + cSerieUsina
		cRetorno	+= ", DATA EMISSAO " + DtoC(dDataNotaEntrada)
		cRetorno	+= ", VALOR " + AllTrim(Str(nValorItem)) + "."
		//cRetorno	+= " NF DE ENTRADA: " + IIF(Empty(cNumeroQuartaNota), cNumeroNotaUsina, cNumeroQuartaNota) + "."

	ElseIf cCFOPMensagem == "901"
		cRetorno	:= "MATERIAL QUE ESTAMOS ENVIANDO PARA INDUSTRIALIZAÇĂO COM POSTERIOR RETORNO."
		cRetorno	+= " INSP.: " + cNumeroInspecao
		cRetorno	+= " / ID BOBINA: " + cLoteBobina + "."

	ElseIf cCFOPMensagem == "924"
		cRetorno	:= "REMESSA PARA INDUSTRIALIZAÇĂO ENTREGUE PELO PRIMEIRO BENEFICIADOR POR CONTA E ORDEM DO AUTOR DA ENCOMENDA -"

		If cTipoNotaEntrada == "B"
			buscaDadosCliente()

			cRetorno	+= " CLIENTE " + AllTrim((cAliasCliente)->A1_NOME)
			cRetorno	+= " SITUADA A " + AllTrim((cAliasCliente)->A1_END) + " " + AllTrim((cAliasCliente)->A1_COMPLEM)
			cRetorno	+= " " + AllTrim((cAliasCliente)->A1_BAIRRO)
			cRetorno	+= "/" + AllTrim((cAliasCliente)->A1_MUN)
			cRetorno	+= " - " + AllTrim((cAliasCliente)->A1_EST)
			cRetorno	+= " - CNPJ: " + AllTrim((cAliasCliente)->A1_CGC) + "."
			cRetorno	+= " Insc. Est. " + AllTrim((cAliasCliente)->A1_INSCR)

			(cAliasCliente)->(DbCloseArea())

		ElseIf cTipoNotaEntrada == "N"
			cRetorno	+= " FORNECEDOR " + AllTrim((cAliasFornecedor)->A2_NOME)
			cRetorno	+= " SITUADA A " + AllTrim((cAliasFornecedor)->A2_END) + " " + AllTrim((cAliasFornecedor)->A2_NR_END)
			cRetorno	+= " " + AllTrim((cAliasFornecedor)->A2_BAIRRO)
			cRetorno	+= "/" + AllTrim((cAliasFornecedor)->A2_MUN)
			cRetorno	+= " - " + AllTrim((cAliasFornecedor)->A2_EST)
			cRetorno	+= " - CNPJ: " + AllTrim((cAliasFornecedor)->A2_CGC) + "."
			cRetorno	+= " Insc. Est. " + AllTrim((cAliasFornecedor)->A2_INSCR)
		EndIf

		cRetorno	+= " ID MATERIA PRIMA: " + cLoteBobina
	EndIf

	If !Empty(cRetorno)
		cIDBobinaMensagem	+= cLoteBobina + "/"
	EndIf

	(cAliasFornecedor)->(DbCloseArea())
Return cRetorno

/*
	Monta mensagem comercial
*/
Static Function montaMensagemComercial()
	Local cRetorno	:= ""	as character
	Local cItemNota	:= AllTrim(Str(aProdutos[nProduto][1]))	as character

	If cCFOPMensagem $ "124/125/902/925"
		cRetorno	+= "(ITEM "+cItemNota+") "
		cRetorno	+= "NF.:" + IIF(Empty(cNumeroNotaUsina), cNumeroQuartaNota, cNumeroNotaUsina)
		cRetorno	+= "/No.Inspecao: " + AllTrim(cNumeroInspecao)
		cRetorno	+= "/DATA: " + DtoC(dDataNotaEntrada) //IIF(Empty(dDataQuartaNota), "", DtoC(dDataQuartaNota))
		cRetorno	+= ValPaXPeso()
		cRetorno	+= "/Cod.Bob.: " + AllTrim(cLoteBobina)
		cRetorno	+= "/NF.Ent.: " + IIF(Empty(cNumeroNotaUsina), cNumeroQuartaNota, cNumeroNotaUsina)

		If cCFOPMensagem $ "124/125" //Empty(aProdutos[nProduto][39])
			cRetorno	+= "/Lotes: " + informacaoLotes()
		EndIf
	EndIf
Return cRetorno

/*
	Nota da Usina
*/
Static Function notaUsina()
	Local cQuery	:= ""	as character
	Local cAlias

	cQuery := 	queryNotaUsina()

	MPSysOpenQuery( cQuery, cAlias := GetNextAlias() )

	(cAlias)->(DbGoTop())
	If (cAlias)->(!EoF())
		If Empty((cAlias)->D1_ZNFUSIN)
			cNumeroNotaUsina	:= (cAlias)->D1_DOC
			cSerieUsina			:= (cAlias)->D1_SERIE
			cTipoNotaEntrada	:= (cAlias)->D1_TIPO
			cCodigoFornecedor	:= (cAlias)->D1_FORNECE
			cLojaFornecedor		:= (cAlias)->D1_LOJA
			dDataNotaEntrada	:= StoD((cAlias)->D1_EMISSAO)
			nValorItem			:= (cAlias)->D1_TOTAL
			cNumeroInspecao		:= (cAlias)->D1_LOTEFOR
			cLoteBobina			:= (cAlias)->D1_LOTECTL
			cNumeroNotaCliente	:= (cAlias)->DH_DOC
			cClienteNota		:= (cAlias)->DH_CLIENTE
			cLojaNota			:= (cAlias)->DH_LOJACLI
		Else
			cNumeroNotaUsina	:= (cAlias)->D1_ZNFUSIN
			cSerieUsina			:= (cAlias)->D1_SERIE
			cTipoNotaEntrada	:= (cAlias)->D1_TIPO
			cCodigoFornecedor	:= (cAlias)->D1_FORNECE
			cLojaFornecedor		:= (cAlias)->D1_LOJA
			dDataNotaEntrada	:= StoD((cAlias)->D1_EMISSAO)
			nValorItem			:= (cAlias)->D1_TOTAL
			cNumeroInspecao		:= (cAlias)->D1_LOTEFOR
			cLoteBobina			:= (cAlias)->D1_LOTECTL
			cNumeroNotaCliente	:= (cAlias)->D1_DOC
		EndIf
	EndIf

	(cAlias)->(DbCloseArea())
Return

/*
	Query da Nota da Usina
*/
Static Function queryNotaUsina()
	Local cQuery	:= ""	as character

	cQuery += " SELECT " + CRLF
	cQuery += "        D1_DOC "	+ CRLF
	cQuery += "        ,D1_SERIE "	+ CRLF
	cQuery += "        ,D1_TIPO "	+ CRLF
	cQuery += "        ,D1_FORNECE "	+ CRLF
	cQuery += "        ,D1_LOJA "	+ CRLF
	cQuery += "        ,D1_LOTEFOR "	+ CRLF
	cQuery += "        ,D1_EMISSAO "	+ CRLF
	cQuery += "        ,D1_TOTAL "	+ CRLF
	cQuery += "        ,D1_LOTECTL "	+ CRLF
	cQuery += "        ,D1_ZNFUSIN "	+ CRLF
	cQuery += "        ,DH_DOC "	+ CRLF
	cQuery += "        ,DH_CLIENTE "	+ CRLF
	cQuery += "        ,DH_LOJACLI "	+ CRLF

	cQuery += " FROM " + CRLF
	cQuery += "     " + RetSQLTab("SC5") + CRLF

	cQuery += " INNER JOIN " + CRLF
	cQuery += "     " + RetSQLTab("SD1") + CRLF
	cQuery += "     	ON" + CRLF
	cQuery += " 	    D1_FILIAL = C5_FILIAL " + CRLF
	cQuery += " 	    AND D1_LOTEFOR = C5_ZINSPE" + CRLF
	cQuery += " 	    AND D1_LOTECTL = C5_ZLOTCTL " + CRLF
	cQuery += " 	    AND D1_TP = 'MP' " + CRLF
	cQuery += "	    	AND " + RetSqlDel("SD1") + CRLF

	cQuery += " INNER JOIN " + CRLF
	cQuery += "     " + RetSQLTab("SF1") + CRLF
	cQuery += "     	ON" + CRLF
	cQuery += " 	    F1_FILIAL = D1_FILIAL " + CRLF
	cQuery += " 	    AND F1_DOC = D1_DOC" + CRLF
	cQuery += " 	    AND F1_SERIE = D1_SERIE " + CRLF
	cQuery += " 	    AND F1_FORNECE = D1_FORNECE " + CRLF
	cQuery += " 	    AND F1_LOJA = D1_LOJA " + CRLF
	cQuery += "	    	AND " + RetSqlDel("SF1") + CRLF

	cQuery += " LEFT JOIN " + CRLF
	cQuery += "     " + RetSQLTab("SDH") + CRLF
	cQuery += "     	ON" + CRLF
	cQuery += " 	    DH_FILIAL = D1_FILIAL " + CRLF
	cQuery += " 	    AND DH_NDOC = D1_DOC " + CRLF
	cQuery += " 	    AND DH_SDOC = D1_SERIE " + CRLF
	cQuery += "	    	AND " + RetSqlDel("SDH") + CRLF

	cQuery += " WHERE " + CRLF
	cQuery += " 	    1 = 1 " + CRLF
	cQuery += "	 		AND " + RetSqlFil("SC5") + CRLF
	cQuery += " 		AND C5_NUM  = '"+IIF(lRefaturamento, cPedidoOriginal, aProdutos[nProduto][38])+"' " + CRLF
	cQuery += " 		AND ( D1_TIPO  = 'N' OR ( D1_TIPO  = 'B' AND F1_ESPECIE <> 'GER' ) )" + CRLF
	cQuery += "	    	AND " + RetSqlDel("SC5") + CRLF
Return cQuery

/*
	Quarta Nota
*/
Static Function dadosQuartaNota()
	Local cQuery	:= ""	as character
	Local cAlias

	cQuery := 	queryDadosQuartaNota()

	MPSysOpenQuery( cQuery, cAlias := GetNextAlias() )

	(cAlias)->(DbGoTop())
	If (cAlias)->(!EoF())
		cNumeroQuartaNota	:= (cAlias)->D1_DOC
		dDataQuartaNota		:= StoD((cAlias)->D1_EMISSAO)
	EndIf

	(cAlias)->(DbCloseArea())
Return

/*
	Query da Quarta Nota
*/
Static Function queryDadosQuartaNota()
	Local cQuery	:= ""	as character

	cQuery += " SELECT " + CRLF
	cQuery += "        D1_DOC "		+ CRLF
	cQuery += "        ,D1_EMISSAO "		+ CRLF

	cQuery += " FROM " + CRLF
	cQuery += "     " + RetSQLTab("SDH") + CRLF

	cQuery += " INNER JOIN " + CRLF
	cQuery += "     " + RetSQLTab("SD1") + CRLF
	cQuery += "     	ON" + CRLF
	cQuery += " 	    D1_FILIAL = DH_FILIAL " + CRLF
	cQuery += " 	    AND D1_NUMSEQ = DH_IDENTNF " + CRLF
	cQuery += "	    	AND " + RetSqlDel("SD1") + CRLF

	cQuery += " WHERE " + CRLF
	cQuery += " 	    1 = 1 " + CRLF
	cQuery += "	 		AND " + RetSqlFil("SDH") + CRLF
	cQuery += " 		AND DH_DOC  = '"+cNumeroNotaCliente+"' " + CRLF
	cQuery += " 		AND DH_CLIENTE  = '"+cClienteNota+"' " + CRLF
	cQuery += " 		AND DH_LOJACLI  = '"+cLojaNota+"' " + CRLF
	cQuery += " 		AND DH_TPMOV  = '2' " + CRLF
	cQuery += "	    	AND " + RetSqlDel("SDH") + CRLF
Return cQuery

/*
	Valida se a mensagem deve sair no item
*/
Static Function validaMensagemNoItem()
	Local cQuery	:= ""	as character
	Local cAlias
	Local lRetorno	:= .F.	as logical

	cQuery := 	queryValidaMensagemNoItem()

	MPSysOpenQuery( cQuery, cAlias := GetNextAlias() )

	(cAlias)->(DbGoTop())
	While (cAlias)->(!EoF())
		If SubStr((cAlias)->C6_CF,2,3) $ "124/125/901/903/902/924/925"
			lRetorno		:= .T.
			//cCFOPMensagem	:= SubStr((cAlias)->C6_CF,2,3)
		EndIf

		(cAlias)->(DbSkip())
	EndDo

	(cAlias)->(DbCloseArea())
Return lRetorno

/*
	Query Valida se a mensagem deve sair no item
*/
Static Function queryValidaMensagemNoItem()
	Local cQuery	:= ""	as character

	cQuery += " SELECT " + CRLF
	cQuery += "        C6_CF "		+ CRLF

	cQuery += " FROM " + CRLF
	cQuery += "     " + RetSQLTab("SC6") + CRLF

	cQuery += " WHERE " + CRLF
	cQuery += " 	    1 = 1 " + CRLF
	cQuery += "	 		AND " + RetSqlFil("SC6") + CRLF
	cQuery += " 		AND C6_NOTA		= '"+SF2->F2_DOC+"' " + CRLF
	cQuery += " 		AND C6_SERIE	= '"+SF2->F2_SERIE+"' " + CRLF
	cQuery += "	    	AND " + RetSqlDel("SC6") + CRLF
Return cQuery

/*
	Busca Valor e Peso
*/
Static Function ValPaXPeso()
	Local cQuery			:= "" as character
	Local cAlias
	Local cRetorno			:= "" as character

	cQuery	:= queryValPaXPeso()

	MPSysOpenQuery( cQuery, cAlias := GetNextAlias() )

	(cAlias)->(DbGoTop())
	If (cAlias)->(!EoF())
		/*cRetorno	:= "/VALOR: " + AllTrim((Transform(SD2->D2_TOTAL, "@E 999,999,999,999.99"))) +;
						"/PESO: " + AllTrim((Transform(IIF(SD2->D2_TP == "MP" .And. (cAlias)->C6_ZUMNFE == "TL", SD2->D2_QUANT / 1000, SD2->D2_QUANT), "@E 999,999,999.9999")))*/
		cRetorno	:= "/VALOR: " + AllTrim((Transform(aProdutos[nProduto][10], "@E 999,999,999,999.99"))) +;
						"/PESO: " + AllTrim((Transform(IIF((cAlias)->B1_TIPO == "MP", aProdutos[nProduto][9], (cAlias)->C6_ZPESO), "@E 999,999,999.9999")))

		If !(cAlias)->B1_TIPO == "MP"
			cRetorno	+= calculaPesoTotal((cAlias)->C6_ZPESO)
		Else
			If (cAlias)->C6_QTDVEN > (cAlias)->C6_QTDENT
				cRetorno	+= " (Parcial)"
			Else
				cRetorno	+= " (Saldo)"
			EndIf
		EndIf
	EndIf

	(cAlias)->(DbCloseArea())
Return cRetorno

/*
	Query Valor e Peso
*/
Static Function queryValPaXPeso()
	Local cQuery	:= ""	as character

	cQuery += " SELECT " + CRLF
	/*cQuery += "        SUM(D2_QUANT) AS QUANT "		+ CRLF
	cQuery += "        ,C6_VALOR AS VALOR_TOTAL "		+ CRLF
	cQuery += "        ,C6_QTDVEN AS QTD_TOTAL "		+ CRLF
	cQuery += "        ,C6_ZUMNFE AS C6_ZUMNFE "		+ CRLF*/
	If !Empty(aProdutos[nProduto][39])
		cQuery += "        C6_QTDVEN "		+ CRLF
		cQuery += "        ,C6_QTDENT "		+ CRLF
		cQuery += "        ,C6_ZPESO "		+ CRLF
		cQuery += "        ,B1_TIPO "		+ CRLF
	Else
		cQuery += "        SUM(C6_QTDVEN) C6_QTDVEN "		+ CRLF
		cQuery += "        ,SUM(C6_QTDENT) C6_QTDENT "		+ CRLF
		cQuery += "        ,SUM(C6_ZPESO) C6_ZPESO "		+ CRLF
		cQuery += "        ,B1_TIPO "		+ CRLF
	EndIf

	cQuery += " FROM " + CRLF
	//cQuery += "     " + RetSQLTab("SD2") + CRLF
	cQuery += "     " + RetSQLTab("SC6") + CRLF

	/*cQuery += " INNER JOIN " + CRLF
	cQuery += "     " + RetSQLTab("SC6") + CRLF
	cQuery += "     	ON" + CRLF
	cQuery += " 	    " + RetSqlFil("SC6") + CRLF
	cQuery += " 	    AND C6_NUM		= '"+SD2->D2_PEDIDO+"' " + CRLF
	cQuery += "	    	AND " + RetSqlDel("SC6") + CRLF*/

	cQuery += " INNER JOIN " + CRLF
	cQuery += "     " + RetSQLTab("SB1") + CRLF
	cQuery += "     	ON" + CRLF
	cQuery += " 	    " + RetSqlFil("SB1") + CRLF
	cQuery += " 	    AND B1_COD		= C6_PRODUTO " + CRLF
	//cQuery += " 	    AND B1_TIPO		= 'MP' " + CRLF
	cQuery += "	    	AND " + RetSqlDel("SB1") + CRLF

	cQuery += " WHERE " + CRLF
	cQuery += " 	    1 = 1 " + CRLF
	/*cQuery += "	 		AND " + RetSqlFil("SD2") + CRLF
	cQuery += " 		AND D2_DOC		= '"+SD2->D2_DOC+"' " + CRLF
	cQuery += " 		AND D2_SERIE	= '"+SD2->D2_SERIE+"' " + CRLF
	cQuery += " 		AND D2_PEDIDO	= '"+SD2->D2_PEDIDO+"' " + CRLF
	cQuery += " 		AND D2_ITEMPV	= '"+SD2->D2_ITEMPV+"' " + CRLF
	cQuery += " 		AND D2_TP		= 'PA' " + CRLF
	cQuery += "	    	AND " + RetSqlDel("SD2") + CRLF*/

	cQuery += "	 		AND " + RetSqlFil("SC6") + CRLF
	cQuery += " 		AND C6_NOTA		= '"+SF2->F2_DOC+"' " + CRLF
	cQuery += " 		AND C6_SERIE	= '"+SF2->F2_SERIE+"' " + CRLF
	cQuery += " 		AND C6_NUM		= '"+aProdutos[nProduto][38]+"' " + CRLF
	cQuery += " 		AND C6_PRODUTO	= '"+aProdutos[nProduto][2]+"' " + CRLF
	
	If !Empty(aProdutos[nProduto][39])
		cQuery += " 		AND C6_ITEM		= '"+aProdutos[nProduto][39]+"' " + CRLF
	EndIf

	cQuery += "	    	AND " + RetSqlDel("SC6") + CRLF

	//cQuery += " GROUP BY C6_VALOR, C6_QTDVEN, C6_ZUMNFE " + CRLF
	
	If Empty(aProdutos[nProduto][39])
		cQuery += " GROUP BY B1_TIPO " + CRLF
	EndIf
Return cQuery

/*
	Busca informacao dos lotes aglutinados
*/
Static Function informacaoLotes()
	Local cQuery	:= ""	as character
	Local cAlias
	Local cRetorno	:= ""	as character
	Local cPecas	:= ""	as character

	cQuery	:= queryInformacaoLotes()

	MPSysOpenQuery( cQuery, cAlias := GetNextAlias() )

	(cAlias)->(DbGoTop())
	While !(cAlias)->(EoF())
		If (cAlias)->C6_UM == "PC"
			cPecas	:= AllTrim(Str((cAlias)->C6_QTDVEN))
		ElseIf SubStr((cAlias)->C6_LOTECTL, 12, 1) == "G"
			cPecas	:= "N/A"
		Else
			cPecas	:= "1"
		EndIf

		cRetorno	+= " (" + AllTrim((cAlias)->C6_LOTECTL) + ", " + cPecas + " peças, peso " + AllTrim(Str(IIF((cAlias)->C6_ZQTDNFE > 0, (cAlias)->C6_ZQTDNFE, (cAlias)->C6_ZPESO))) + " )"

		(cAlias)->(DbSkip())
	EndDo

	(cAlias)->(DbCloseArea())
Return cRetorno

/*
	Query Informaçőes dos lotes aglutinados
*/
Static Function queryInformacaoLotes()
	Local cQuery	:= ""	as character

	cQuery += " SELECT " + CRLF
	cQuery += "        C6_LOTECTL "		+ CRLF
	cQuery += "        ,C6_QTDVEN "		+ CRLF
	cQuery += "        ,C6_ZQTDNFE "		+ CRLF
	cQuery += "        ,C6_ZPESO "		+ CRLF
	cQuery += "        ,C6_UM "		+ CRLF

	cQuery += " FROM " + CRLF
	cQuery += "     " + RetSQLTab("SC6") + CRLF

	cQuery += " WHERE " + CRLF
	cQuery += " 	    1 = 1 " + CRLF
	cQuery += "	 		AND " + RetSqlFil("SC6") + CRLF
	cQuery += " 		AND C6_NOTA		= '"+SF2->F2_DOC+"' " + CRLF
	cQuery += " 		AND C6_SERIE	= '"+SF2->F2_SERIE+"' " + CRLF
	cQuery += " 		AND C6_NUM		= '"+aProdutos[nProduto][38]+"' " + CRLF
	cQuery += " 		AND C6_PRODUTO	= '"+aProdutos[nProduto][2]+"' " + CRLF
	cQuery += "	    	AND " + RetSqlDel("SC6") + CRLF
Return cQuery

/*
	Valida Refaturamento
*/
Static Function validaRefaturamento()
	Local cQuery			:= ""	as character
	Local cAlias

	cQuery := 	queryValidaRefaturamento()

	MPSysOpenQuery( cQuery, cAlias := GetNextAlias() )

	(cAlias)->(DbGoTop())
	If (cAlias)->(!EoF())
		lRefaturamento	:= .T.

		cNotaRefaturamento			:= (cAlias)->Z7_NUMNF
		cSerieRefaturamento			:= (cAlias)->Z7_SERIE
		cFornecedorRefaturamento	:= (cAlias)->Z7_FORNECE
		cLojaRefaturamento			:= (cAlias)->Z7_LOJA

		buscaPedidoOriginal()
	EndIf

	(cAlias)->(DbCloseArea())
Return

/*
	Query valida regaturamento
*/
Static Function queryValidaRefaturamento()
	Local cQuery	:= ""	as character

	cQuery += " SELECT " + CRLF
	cQuery += "        Z7_NUMNF " + CRLF
	cQuery += "        ,Z7_SERIE " + CRLF
	cQuery += "        ,Z7_FORNECE " + CRLF
	cQuery += "        ,Z7_LOJA " + CRLF

	cQuery += " FROM " + CRLF
	cQuery += "     " + RetSQLTab("SZ7") + CRLF

	cQuery += " WHERE " + CRLF
	cQuery += " 	    1 = 1 " + CRLF
	cQuery += "	 		AND " + RetSqlFil("SZ7") + CRLF
	cQuery += " 		AND Z7_NUMPV	= '"+aProdutos[nProduto][38]+"' " + CRLF
	cQuery += "	    	AND " + RetSqlDel("SZ7") + CRLF
Return cQuery

/*
	Busca pedido original
*/
Static Function buscaPedidoOriginal()
	Local cQuery	:= ""	as character
	Local cAlias

	cQuery := 	queryBuscaPedidoOriginal()

	MPSysOpenQuery( cQuery, cAlias := GetNextAlias() )

	(cAlias)->(DbGoTop())
	If (cAlias)->(!EoF())
		cPedidoOriginal	:= (cAlias)->D2_PEDIDO
	EndIf

	(cAlias)->(DbCloseArea())
Return

/*
	Query da Busca pedido original
*/
Static Function queryBuscaPedidoOriginal()
	Local cQuery	:= ""	as character

	cQuery += " SELECT " + CRLF
	cQuery += "        D2_PEDIDO "	+ CRLF

	cQuery += " FROM " + CRLF
	cQuery += "     " + RetSQLTab("SD1") + CRLF

	cQuery += " INNER JOIN " + CRLF
	cQuery += "     " + RetSQLTab("SD2") + CRLF
	cQuery += "     	ON" + CRLF
	cQuery += " 	    D2_FILIAL		= D1_FILIAL " + CRLF
	cQuery += " 	    AND D2_DOC		= D1_NFORI" + CRLF
	cQuery += " 	    AND D2_SERIE	= D1_SERIORI " + CRLF
	cQuery += " 	    AND D2_ITEM		= D1_ITEMORI " + CRLF
	cQuery += "	    	AND " + RetSqlDel("SD2") + CRLF

	cQuery += " WHERE " + CRLF
	cQuery += " 	    1 = 1 " + CRLF
	cQuery += "	 		AND " + RetSqlFil("SD1") + CRLF
	cQuery += " 		AND D1_DOC		= '"+cNotaRefaturamento+"' " + CRLF
	cQuery += " 		AND D1_SERIE	= '"+cSerieRefaturamento+"' " + CRLF
	cQuery += " 		AND D1_FORNECE	= '"+cFornecedorRefaturamento+"' " + CRLF
	cQuery += " 		AND D1_LOJA		= '"+cLojaRefaturamento+"' " + CRLF
	cQuery += "	    	AND " + RetSqlDel("SD1") + CRLF
Return cQuery

/*
	Busca dados fornecedor
*/
